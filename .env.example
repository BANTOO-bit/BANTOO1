# ========================
# BANTOO - Food Delivery App
# Environment Variables
# ========================

# Supabase Configuration
# Get these from: https://supabase.com/dashboard → Your Project → Settings → API
VITE_SUPABASE_URL=https://your-project-id.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key-here

# ========================
# Firebase Configuration (Push Notifications)
# Get these from: https://console.firebase.google.com → Project Settings
# ========================
VITE_FIREBASE_API_KEY=your-firebase-api-key
VITE_FIREBASE_AUTH_DOMAIN=your-project.firebaseapp.com
VITE_FIREBASE_PROJECT_ID=your-project-id
VITE_FIREBASE_STORAGE_BUCKET=your-project.firebasestorage.app
VITE_FIREBASE_MESSAGING_SENDER_ID=your-sender-id
VITE_FIREBASE_APP_ID=your-app-id
VITE_FIREBASE_MEASUREMENT_ID=G-XXXXXXXXXX
VITE_FIREBASE_VAPID_KEY=your-vapid-key

# ========================
# OPTIONAL (Phase 2+)
# ========================

# Sentry Error Monitoring
# Get DSN from: https://sentry.io → Project Settings → Client Keys (DSN)
# VITE_SENTRY_DSN=https://your-key@o12345.ingest.sentry.io/12345

# Payment Gateway (Midtrans)
# VITE_MIDTRANS_CLIENT_KEY=your-midtrans-client-key
# VITE_MIDTRANS_SERVER_KEY=your-midtrans-server-key
