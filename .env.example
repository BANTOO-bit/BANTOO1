# ========================
# BANTOO - Food Delivery App
# ========================
# Copy file ini ke .env dan isi dengan credentials Anda sendiri.
# JANGAN commit file .env ke Git!

# Supabase Configuration
# Langkah: https://supabase.com/dashboard → Project → Settings → API
VITE_SUPABASE_URL=https://your-project-ref.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key-here

# Firebase Configuration (Push Notifications)
# Langkah: https://console.firebase.google.com → Project Settings → General
VITE_FIREBASE_API_KEY=your-firebase-api-key
VITE_FIREBASE_AUTH_DOMAIN=your-project.firebaseapp.com
VITE_FIREBASE_PROJECT_ID=your-project-id
VITE_FIREBASE_STORAGE_BUCKET=your-project.firebasestorage.app
VITE_FIREBASE_MESSAGING_SENDER_ID=000000000000
VITE_FIREBASE_APP_ID=1:000000000000:web:0000000000000000
VITE_FIREBASE_MEASUREMENT_ID=G-XXXXXXXXXX
VITE_FIREBASE_VAPID_KEY=your-vapid-key-here

# Sentry Error Monitoring (Optional - leave empty to disable)
VITE_SENTRY_DSN=
